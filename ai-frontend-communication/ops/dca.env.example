DCA_PUBLIC_URL=https://agency.kakaduai.com
DCA_DATABASE_URL=postgresql+psycopg://dca:CHANGE_ME@127.0.0.1:5433/dca
DCA_REDIS_URL=redis://127.0.0.1:6380/0

DCA_TELEGRAM_BOT_TOKEN=CHANGE_ME
DCA_TELEGRAM_MODE=polling
# Required only when DCA_TELEGRAM_MODE=webhook.
DCA_TELEGRAM_WEBHOOK_SECRET=
# Required on networks where Telegram/Claude must use an HTTP CONNECT proxy.
# DCA_OUTBOUND_PROXY_URL=http://user:password@proxy.example:8080

# Generate with: openssl rand -hex 32. Use the same value in the GitHub webhook.
DCA_GITHUB_WEBHOOK_SECRET=
DCA_MAX_GITHUB_WEBHOOK_BODY_BYTES=1048576
DCA_REPOSITORY_RECONCILE_SECONDS=300

DCA_SESSION_SECRET=CHANGE_ME
DCA_COOKIE_SECURE=true

# Optional fallback. Prefer entering this credential in Agent -> Claude Code CLI after first login.
CLAUDE_CODE_OAUTH_TOKEN=
DCA_CLAUDE_BIN=/usr/bin/claude
DCA_CLAUDE_SESSION_ROOT=/var/lib/dca/claude-sessions
DCA_REPOSITORY_ROOT=/var/lib/dca/repositories
DCA_SNAPSHOT_ROOT=/var/lib/dca/snapshots

DCA_LOG_LEVEL=INFO
DCA_WORKER_POLL_SECONDS=0.25
DCA_KNOWLEDGE_CONCURRENCY=5
DCA_MAX_TELEGRAM_BODY_BYTES=1048576
