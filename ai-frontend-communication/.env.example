# Public URLs. DCA_DOMAIN is consumed by Docker Compose/Caddy.
DCA_DOMAIN=developer-agent.example.com
DCA_PUBLIC_URL=https://developer-agent.example.com
POSTGRES_PASSWORD=dca
DCA_DATABASE_URL=postgresql+psycopg://dca:dca@postgres:5432/dca
DCA_REDIS_URL=redis://redis:6379/0

# Telegram transport. Production can use outbound-only polling; webhook remains supported.
DCA_TELEGRAM_BOT_TOKEN=
DCA_TELEGRAM_MODE=polling
# Required only for webhook mode. Generate with: openssl rand -hex 32
DCA_TELEGRAM_WEBHOOK_SECRET=
# Shared HTTP(S) proxy for Telegram and Claude Code. Claude Code does not support SOCKS.
# DCA_OUTBOUND_PROXY_URL=http://proxy-user:proxy-password@127.0.0.1:8080

# Admin cookies and HMAC-SHA-256 access-key fingerprints. Use at least 32 random characters.
DCA_SESSION_SECRET=
DCA_COOKIE_SECURE=true

# Claude Code subscription credential created by: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
DCA_CLAUDE_BIN=claude
DCA_REPOSITORY_ROOT=/runtime/repositories
DCA_SNAPSHOT_ROOT=/runtime/snapshots

# Operational limits
DCA_LOG_LEVEL=INFO
DCA_WORKER_POLL_SECONDS=2
DCA_CLAUDE_TIMEOUT_SECONDS=180
DCA_MAX_TELEGRAM_BODY_BYTES=1048576
